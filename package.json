    "pi-extension",
    "mcp",
    "audience",
    "annotations",
    "model-context-protocol"
  ],
  "author": "cwt114",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cwt/pi-mcp-audience.git"
  },
  "homepage": "https://github.com/cwt/pi-mcp-audience",
  "bugs": {
    "url": "https://github.com/cwt/pi-mcp-audience/issues"
  },
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
